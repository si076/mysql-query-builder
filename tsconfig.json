{
  "extends": "@tsconfig/node20/tsconfig.json",
  "compileOnSave": true,
  "compilerOptions": {
    // "module": "nodenext",
    // "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "experimentalDecorators": true,
    "types": [
      "node"
    ],
    "emitDecoratorMetadata": true,
    "allowJs": true,
    // "declaration": true,
    // "declarationMap": true
  },
  "include": [
    "./src/*.ts",
    "./src/**/*.ts"
, "src/test/select.test.ts"  ],
  "exclude": [
    "node_modules"
  ]

}
